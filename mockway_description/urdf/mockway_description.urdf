<?xml version="1.0"?>
<robot name="mockway_description">

  <link name="base_link">
    <inertial>
      <mass value="0.097"/>
      <origin xyz="-0.000 -0.000 0.014" rpy="0 0 0"/>
      <inertia ixx="0.000049" iyy="0.000049" izz="0.000080" ixy="-0.000000" ixz="0.000000" iyz="0.000000"/>
